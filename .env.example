# FraudHunter AI — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to version control

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=FraudHunter AI
DEBUG=false
SECRET_KEY=generate-a-32-char-random-string-here

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://fraud:fraud@localhost:5432/fraudhunter
REDIS_URL=redis://localhost:6379

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TRANSACTIONS=transactions.raw
KAFKA_TOPIC_ALERTS=fraud.alerts

# ─── AI (Required) ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── Risk Thresholds ──────────────────────────────────────────────────────────
RISK_THRESHOLD_CRITICAL=0.90
RISK_THRESHOLD_HIGH=0.70
RISK_THRESHOLD_MEDIUM=0.40

# ─── Model ────────────────────────────────────────────────────────────────────
MODEL_PATH=./models/fraud_model.pkl

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ─── Agents ───────────────────────────────────────────────────────────────────
AGENT_SCAN_INTERVAL_MS=200
MAX_CONCURRENT_AGENTS=10
